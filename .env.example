# ---- Sesión / Auth ----
# Secreto para firmar las cookies de sesión (cualquier cadena larga aleatoria)
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ---- Base de datos (persistencia de usuarios y configuración) ----
# Cadena de conexión Postgres. En Vercel la inyecta la integración Vercel Postgres
# automáticamente (POSTGRES_URL). En local, apunta a esa misma base o a un Postgres propio.
POSTGRES_URL=postgres://usuario:password@host:5432/basedatos

# ---- Modo de datos ----
# mock  -> usa datos de ejemplo (mockup, no necesita Redshift)
# redshift -> consulta Redshift en vivo (con caché)
DATA_SOURCE=mock

# ---- Redshift (solo cuando DATA_SOURCE=redshift) ----
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=
REDSHIFT_USER=
REDSHIFT_PASSWORD=

# Minutos que se cachea el resultado de la query antes de volver a consultar Redshift
DASHBOARD_CACHE_MINUTES=180
